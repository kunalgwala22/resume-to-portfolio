# Server Configuration
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:5173

# Database Connection (PostgreSQL)
DATABASE_URL=postgresql://portfolioverse:password@localhost:5432/portfolioverse?schema=public

# Redis Connection URL
REDIS_URL=redis://localhost:6379

# JWT Authentication Configuration
JWT_ACCESS_SECRET=your_jwt_access_secret_key_at_least_32_characters_long
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_at_least_32_characters_long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Cloudinary Storage SDK keys
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# OpenAI Completion API Configurations
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o

# Rate Limiting Shield Parameters
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10
